
/**
 * @fileoverview Firestore Security Rules for the application.
 * Updated to ensure full access for all authenticated users to all operational and financial data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Simple sign-in check
    function isSignedIn() {
      return request.auth != null;
    }

    // Full access for all collections to any signed-in user
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Specific match for settings to allow public read if necessary, but keep write protected
    match /settings/app {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
