
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permet l'accès complet à toutes les collections pour tout utilisateur authentifié
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Règle spécifique pour le logo si nécessaire en accès public
    match /settings/app {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
