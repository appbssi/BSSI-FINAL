
/**
 * @fileoverview Firestore Security Rules for the application.
 * Updated to allow full access to financial and operational records for all signed-in users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Simple sign-in check
    function isSignedIn() {
      return request.auth != null;
    }

    // Access for agents
    match /agents/{agentId} {
      allow read, write: if isSignedIn();
    }

    // Access for missions
    match /missions/{missionId} {
      allow read, write: if isSignedIn();
    }

    // Access for gatherings
    match /gatherings/{gatheringId} {
      allow read, write: if isSignedIn();
    }

    // Access for financial expenses
    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    // Access for agent allocations
    match /allocations/{allocationId} {
      allow read, write: if isSignedIn();
    }

    // Public settings (logo, etc.)
    match /settings/app {
      allow get: if true;
      allow list: if false;
      allow write: if isSignedIn();
    }

    // Access for visitors
    match /visitors/{visitorId} {
      allow read, write: if isSignedIn();
    }

    // Access for activity logs
    match /activities/{activityId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }

  }
}
