
{
  "entities": {
    "Agent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Agent",
      "type": "object",
      "description": "Represents an agent who can be assigned to missions.",
      "properties": {
        "fullName": { "type": "string" },
        "registrationNumber": { "type": "string" },
        "rank": { "type": "string" },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "section": { "type": "string" },
        "leaveStartDate": { "type": "string", "format": "date-time" },
        "leaveEndDate": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "rank", "address", "section"]
    },
    "Mission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Mission",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Planification", "En cours", "Terminée", "Annulée"] },
        "assignedAgentIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "location", "startDate", "endDate", "status", "assignedAgentIds"]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["Opérationnel", "Matériel", "Transport", "Logistique", "Autre"] },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Validé", "En attente", "Refusé"] },
        "missionId": { "type": ["string", "null"] }
      },
      "required": ["description", "amount", "category", "date", "status"]
    },
    "Allocation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Allocation",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "amount": { "type": "number" },
        "purpose": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "amount", "purpose", "date"]
    },
    "Detainee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Detainee",
      "type": "object",
      "description": "Représente une personne en Garde À Vue.",
      "properties": {
        "lastName": { "type": "string" },
        "firstName": { "type": "string" },
        "birthDate": { "type": "string", "format": "date-time" },
        "photo": { "type": "string", "description": "Data URI de la photo d'identité" },
        "entryTime": { "type": "string", "format": "date-time" },
        "arrestLocation": { "type": "string" },
        "arrestReason": { "type": "string" }
      },
      "required": ["lastName", "firstName", "birthDate", "entryTime", "arrestLocation", "arrestReason"]
    }
  },
  "firestore": {
    "/agents/{agentId}": { "schema": { "$ref": "#/entities/Agent" } },
    "/missions/{missionId}": { "schema": { "$ref": "#/entities/Mission" } },
    "/expenses/{expenseId}": { "schema": { "$ref": "#/entities/Expense" } },
    "/allocations/{allocationId}": { "schema": { "$ref": "#/entities/Allocation" } },
    "/detainees/{detaineeId}": { "schema": { "$ref": "#/entities/Detainee" } }
  }
}
