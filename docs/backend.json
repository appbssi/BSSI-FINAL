
{
  "entities": {
    "Agent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Agent",
      "type": "object",
      "description": "Represents an agent who can be assigned to missions.",
      "properties": {
        "fullName": { "type": "string" },
        "registrationNumber": { "type": "string" },
        "rank": { "type": "string" },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "section": { "type": "string" },
        "photo": { "type": "string", "description": "Data URI de la photo d'identité" },
        "leaveStartDate": { "type": "string", "format": "date-time" },
        "leaveEndDate": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "rank", "address", "section"]
    },
    "Mission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Mission",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Planification", "En cours", "Terminée", "Annulée"] },
        "assignedAgentIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "location", "startDate", "endDate", "status", "assignedAgentIds"]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["Opérationnel", "Matériel", "Transport", "Logistique", "Autre"] },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Validé", "En attente", "Refusé"] },
        "missionId": { "type": ["string", "null"] }
      },
      "required": ["description", "amount", "category", "date", "status"]
    },
    "Weapon": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Weapon",
      "type": "object",
      "properties": {
        "serialNumber": { "type": "string" },
        "model": { "type": "string" },
        "type": { "type": "string", "enum": ["Arme de poing", "Fusil d'assaut", "Munition", "Accessoire", "Casque", "Gillet Par balle"] },
        "status": { "type": "string", "enum": ["Fonctionnel", "En maintenance", "Hors service"] },
        "quantity": { "type": "number" },
        "lastMaintenanceDate": { "type": "string", "format": "date-time" }
      },
      "required": ["serialNumber", "model", "type", "status"]
    },
    "WeaponAssignment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WeaponAssignment",
      "type": "object",
      "properties": {
        "weaponId": { "type": "string" },
        "agentId": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" },
        "returnedAt": { "type": ["string", "null"], "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["weaponId", "agentId", "assignedAt"]
    },
    "Detainee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Detainee",
      "type": "object",
      "description": "Représente une personne en Garde À Vue.",
      "properties": {
        "lastName": { "type": "string" },
        "firstName": { "type": "string" },
        "birthDate": { "type": "string", "format": "date-time" },
        "photo": { "type": "string", "description": "Data URI de la photo d'identité" },
        "entryTime": { "type": "string", "format": "date-time" },
        "arrestLocation": { "type": "string" },
        "arrestReason": { "type": "string" }
      },
      "required": ["lastName", "firstName", "birthDate", "entryTime", "arrestLocation", "arrestReason"]
    }
  },
  "firestore": {
    "/agents/{agentId}": { "schema": { "$ref": "#/entities/Agent" } },
    "/missions/{missionId}": { "schema": { "$ref": "#/entities/Mission" } },
    "/expenses/{expenseId}": { "schema": { "$ref": "#/entities/Expense" } },
    "/weapons/{weaponId}": { "schema": { "$ref": "#/entities/Weapon" } },
    "/weaponAssignments/{assignmentId}": { "schema": { "$ref": "#/entities/WeaponAssignment" } },
    "/detainees/{detaineeId}": { "schema": { "$ref": "#/entities/Detainee" } }
  }
}
